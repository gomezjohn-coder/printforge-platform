{
  "family": "printforge-monolith",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/printforge-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/printforge-monolith-task-role",
  "containerDefinitions": [
    {
      "name": "monolith-service",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/printforge/monolith-service:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 4000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "4000" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:printforge/monolith/database-url"
        },
        {
          "name": "SESSION_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:printforge/monolith/session-secret"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:4000/healthz || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/printforge-monolith",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "monolith",
          "awslogs-create-group": "true"
        }
      },
      "linuxParameters": {
        "initProcessEnabled": true
      },
      "ulimits": [
        {
          "name": "nofile",
          "softLimit": 65536,
          "hardLimit": 65536
        }
      ],
      "cpu": 256,
      "memory": 512,
      "memoryReservation": 256
    }
  ],
  "tags": [
    { "key": "Project", "value": "PrintForge" },
    { "key": "Component", "value": "monolith-service" },
    { "key": "ManagedBy", "value": "terraform" },
    { "key": "MigrationStatus", "value": "in-progress" }
  ]
}
