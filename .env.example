# PrintForge Environment Configuration
# Copy this to .env and fill in values

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=printforge
POSTGRES_USER=printforge
POSTGRES_PASSWORD=changeme

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Services
MARKETPLACE_API_PORT=3001
MARKETPLACE_WEB_PORT=3000
ARTIST_SERVICE_PORT=8080
SEARCH_SERVICE_PORT=3002
MONOLITH_PORT=4000

# Datadog (optional for local dev)
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com

# AWS (for Terraform)
AWS_REGION=ap-southeast-2
AWS_ACCOUNT_ID=

# Cloudflare (for Terraform)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Environment
NODE_ENV=development
LOG_LEVEL=debug
